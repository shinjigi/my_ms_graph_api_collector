{
    "compilerOptions": {
        "target":            "ES2022",
        "module":            "CommonJS",
        "moduleResolution":  "node",
        "esModuleInterop":   true,
        "allowJs":           true,
        "checkJs":           false,
        "strict":            true,
        "skipLibCheck":      true,
        "outDir":            "dist",
        "resolveJsonModule": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "web", "tp", "dist", "zucchetti_automation"]
}
