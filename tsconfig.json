{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "ESNext.String", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"]
    },
    "sourceMap": true
  },
  "include": ["src/**/*.ts", "shared/**/*.ts"],
  "exclude": ["node_modules", "web", "dist", "scripts", "zucchetti_automation"]
}
