{
  "name": "my_ms_graph_api_collector",
  "version": "1.0.0",
  "description": "Collector Node.js per Microsoft Graph (email, calendario, Teams)",
  "main": "src/index.ts",
  "type": "commonjs",
  "scripts": {
    "start": "tsx src/index.ts",
    "collect": "tsx src/index.ts",
    "collect:force": "tsx src/index.ts --force",
    "collect:range:zucchetti": "tsx src/collectors/zucchetti/getTimesheet.ts --start=2025-06 --end=2025-09",
    "collect:range:nibol": "tsx scripts/nibol/test_calendar.ts --start=2025-06-01 --end=2025-09-30",
    "analyze": "tsx src/analyzer/index.ts",
    "analyze:claude": "tsx src/analysis/analyzer.ts --provider=claude",
    "analyze:gemini": "tsx src/analysis/analyzer.ts --provider=gemini",
    "analyze:cli": "tsx src/analysis/analyzer.ts --provider=cli",
    "kb:update": "tsx src/targetprocess/collector.ts --update-kb",
    "kb:update:force": "tsx src/targetprocess/collector.ts --update-kb --force",
    "kb:update:force:replay": "tsx src/targetprocess/collector.ts --update-kb --force --from-enriched=data/raw/targetprocess/enriched-2026-03-23.json --from-ai-response=data/raw/ai-responses/2026-03-23_175054_gemini_kb-batch-1.json",
    "kb:update:gemini": "tsx src/targetprocess/collector.ts --update-kb --provider=gemini",
    "kb:update:gemini:force": "tsx src/targetprocess/collector.ts --update-kb --provider=gemini --force",
    "serve": "tsx src/server/app.ts",
    "all": "npm run collect && npm run aggregate && npm run analyze && npm run serve",
    "zucchetti:get": "tsx --env-file=.env src/collectors/zucchetti/getTimesheet.ts",
    "zucchetti:get:date": "tsx --env-file=.env src/collectors/zucchetti/getTimesheet.ts --year=2025 --month=6 ",
    "zucchetti:update": "tsx --env-file=.env src/collectors/zucchetti/updateData.ts",
    "tp:log-time": "ts-node --project scripts/tp/tsconfig.json scripts/tp/log-time.ts",
    "tp:projects": "ts-node --project scripts/tp/tsconfig.json scripts/tp/get-projects.ts",
    "tp:userstories": "ts-node --project scripts/tp/tsconfig.json scripts/tp/get-userstories.ts",
    "tp:us-detail": "ts-node --project scripts/tp/tsconfig.json scripts/tp/get-us-detail.ts",
    "nibol:book": "tsx scripts/nibol/book_desk.ts",
    "nibol:book:date": "tsx scripts/nibol/book_desk.ts --date=2026-03-23",
    "nibol:calendar": "tsx scripts/nibol/test_calendar.ts",
    "nibol:status": "tsx scripts/test-nibol.ts"
  },
  "keywords": [
    "microsoft-graph",
    "msal",
    "teams",
    "outlook",
    "calendar",
    "targetprocess",
    "timetracking"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@azure/msal-node": "^2.8.0",
    "@google/genai": "^1.46.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@types/xml2js": "^0.4.14",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "glob": "^13.0.6",
    "isomorphic-fetch": "^3.0.0",
    "playwright": "^1.58.2",
    "sql.js": "^1.14.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^25.4.0",
    "@types/sql.js": "^1.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  }
}
