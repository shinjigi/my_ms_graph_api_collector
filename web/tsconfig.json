{
    "compilerOptions": {
        "target":          "ES2022",
        "module":          "ESNext",
        "moduleResolution": "bundler",
        "strict":          true,
        "jsx":             "preserve",
        "jsxImportSource": "vue",
        "skipLibCheck":    true,
        "resolveJsonModule": true
    },
    "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
