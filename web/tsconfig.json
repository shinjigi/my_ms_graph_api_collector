{
    "compilerOptions": {
        "target":           "ES2022",
        "module":           "ESNext",
        "moduleResolution": "bundler",
        "strict":           true,
        "jsx":              "preserve",
        "jsxImportSource":  "vue",
        "skipLibCheck":     true,
        "resolveJsonModule": true,
        "noEmit":           true,
        "baseUrl":          ".",
        "paths": {
            "@shared/*": ["../shared/*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts", "../shared/**/*.ts"]
}
