TENANT_ID=your-azure-tenant-id
CLIENT_ID=your-azure-app-client-id

# Number of items per endpoint (Graph API)

TOP=50

# ============================================================
# TargetProcess
# ============================================================
TP_BASE_URL=https://your-org.tpondemand.com

# ... == expiring 09/03/2035
TP_TOKEN=your-targetprocess-api-token

# Generic task used for hours that cannot be attributed to any specific item
MISC_TASK_ID=

# ============================================================
# AI analyzer backend — unified analyzer with fallback chain:
#
#   1. Claude API       — set CLAUDE_API_KEY (tried first)
#   2. Gemini API       — set GEMINI_API_KEY (tried second)
#   3. Claude Code CLI  — always available as last resort (uses subscription)
#   4. OpenAI-compatible — set OPENAI_BASE_URL (Ollama, LM Studio, OpenRouter…)
#
# All configured providers are tried in order. Force a specific one with:
#   npm run analyze -- --provider=claude|gemini|cli
#
# ============================================================
# Option 1: Anthropic API
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MODEL_MAX_TPM=200000

# Option 2: Gemini API
# https://aistudio.google.com/rate-limit?timeRange=this-month&project=gen-lang-client-0997119380
# Note: Gemini models have different capabilities. For code analysis, prefer "pro" or "flash" variants.
#       "Lite" models are faster but less accurate.
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL_MAX_TPM=1000000
#GEMINI_MODEL=gemini-1.5-pro
#GEMINI_MODEL=gemini-1.5-flash
#GEMINI_MODEL=gemini-2.0-flash
#GEMINI_MODEL=gemini-2.5-pro
#GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL=gemini-3.1-flash-lite-preview
#GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_MODEL=gemini-1.5-flash # non è stato trovato o non è supportato.
# GEMINI_MODEL=gemini-1.5-flash-8b # non è stato trovato o non è supportato.

# Option 4: OpenAI-compatible (Ollama example)
# File: .env (sul server Debian)
#OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_BASE_URL=http://192.168.1.19:11434/v1
#OPENAI_MODEL=llama3.2
OPENAI_MODEL=qwen2.5-coder:3b
# per convenzione in localhost == ollama
OPENAI_API_KEY=ollama
# Set to the model's context window size in tokens (not throughput):
# qwen2.5-coder:3b = 32768, llama3.2 = 131072, etc.
OPENAI_MODEL_MAX_TPM=32000

# Option 5: Perplexity API
PERPLEXITY_API_KEY=pplx-...

# ============================================================
# Git / SVN commit collectors
# ============================================================
# Semicolon-separated list of root directories to scan for git repos (maxDepth 4).
# Windows paths and WSL UNC paths (forward slashes) are both supported.
# WSL example: //wsl.localhost/Ubuntu/home/<user>/projects
GIT_ROOTS=C:\Projects\;C:\Users\<username>\repos\;//wsl.localhost/Ubuntu/home/<user>/projects

# Semicolon-separated author emails to include (leave empty to include all authors)
GIT_EMAILS=you@company.com;personal@gmail.com

SVN_URL=https://svn.your-company.com/svn/repository/projects/

#SVN_USERNAME=your.username@your-company.com
SVN_USERNAME=your-svn-username
SVN_PASSWORD=your-svn-password

SVN_BIN=C:\Program Files\TortoiseSVN\bin\svn.exe

# ============================================================
# Zucchetti (form-based auth — no SSO)
# ============================================================
ZUCCHETTI_USERNAME=
ZUCCHETTI_PASSWORD=
ZUCCHETTI_HEADLESS=false

# ============================================================
# Nibol (persistent Playwright session)
# ============================================================
#NIBOL_PROFILE_DIR=C:\Users\<username>\.automation-chrome\nibol
NIBOL_PROFILE_DIR=./.automation-chrome/nibol

NIBOL_URL=https://app.nibol.com
NIBOL_USER_NAME=Your Name

# ============================================================
# Browser history — Chrome (semicolon-separated profile dirs)
# ============================================================
CHROME_PROFILE_DIRS=C:\Users\<username>\AppData\Local\Google\Chrome\User Data\Profile 1;C:\Users\<username>\AppData\Local\Google\Chrome\User Data\Profile 2

# ============================================================
# Browser history — Firefox
# ============================================================
FIREFOX_PROFILE_DIR=C:\Users\<username>\AppData\Roaming\Mozilla\Firefox\Profiles\<profile-id>.default-release

# ============================================================
# Historical data range
# ============================================================
COLLECT_SINCE=2025-01-01

# ============================================================
# Confluence Wiki Token
# ============================================================
CONFLUENCE_TOKEN=your-confluence-api-token

# ============================================================
# Obsidian Token
# ============================================================
OBSIDIAN_TOKEN=your-obsidian-token
