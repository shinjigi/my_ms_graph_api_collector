TENANT_ID=your-tenant-id
CLIENT_ID=your-app-client-id
# Number of items per endpoint (Graph API)

TOP=50

# ============================================================
# TargetProcess
# ============================================================
TP_BASE_URL=https://your-org.tpondemand.com


TP_TOKEN=your-targetprocess-api-token
# Generic task used for hours that cannot be attributed to any specific item
MISC_TASK_ID=

# ============================================================
# AI analyzer backend — three mutually exclusive options (first match wins):
#
#   1. Anthropic API    — set CLAUDE_API_KEY
#   2. OpenAI-compatible — set OPENAI_BASE_URL (Ollama, LM Studio, OpenRouter…)
#   3. Claude Code CLI  — leave both unset; uses your Claude Code subscription
#
# ============================================================
# Option 1: Anthropic API
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Option 2: OpenAI-compatible (Ollama example)
#OPENAI_BASE_URL=http://localhost:11434/v1
#OPENAI_API_KEY=ollama
#OPENAI_MODEL=llama3.2

# Option 3: Perplexity API
PERPLEXITY_API_KEY=pplx-...

# ============================================================
# Git / SVN commit collectors
# ============================================================
# Semicolon-separated list of root directories to scan for git repos (maxDepth 4).
# Windows paths and WSL UNC paths (forward slashes) are both supported.
# WSL example: //wsl.localhost/Ubuntu/home/<user>/projects
GIT_ROOTS=C:\Projects\;C:\SVN\_GH\_shinjigi_WIN\;//wsl.localhost/Ubuntu/home/your-username/projects
# Semicolon-separated author emails to include (leave empty to include all authors)
GIT_EMAILS=you@company.com;personal@gmail.com

SVN_URL=https://svn.your-company.com/svn/repository/projects/

#SVN_USERNAME=your.username@your-company.com
SVN_USERNAME=your-svn-username
SVN_PASSWORD=*******

SVN_BIN=C:\Program Files\TortoiseSVN\bin\svn.exe

# ============================================================
# Zucchetti (form-based auth — no SSO)
# ============================================================
ZUCCHETTI_USERNAME=
ZUCCHETTI_PASSWORD=
ZUCCHETTI_HEADLESS=false

# ============================================================
# Nibol (persistent Playwright session)
# ============================================================
NIBOL_PROFILE_DIR=C:\Users\your-username\.automation-chrome\nibol
NIBOL_URL=https://app.nibol.com
NIBOL_USER_NAME=Your Name

# ============================================================
# Browser history — Chrome (semicolon-separated profile dirs)
# ============================================================
CHROME_PROFILE_DIRS=C:\Users\your-username\AppData\Local\Google\Chrome\User Data\Profile 1;C:\Users\your-username\AppData\Local\Google\Chrome\User Data\Profile 2

# ============================================================
# Browser history — Firefox
# ============================================================
FIREFOX_PROFILE_DIR=C:\Users\your-username\AppData\Roaming\Mozilla\Firefox\Profiles\your-profile-id.default-release

# ============================================================
# Historical data range
# ============================================================
COLLECT_SINCE=2025-01-01

# ============================================================
# Confluence Wiki Token
# ============================================================
CONFLUENCE_TOKEN=your-api-token

# ============================================================
# Obsidian Token "for_docker_mcp"
# ============================================================
OBSIDIAN_TOKEN=your-api-token
